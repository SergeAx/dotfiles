{
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(gh issue list *)",
      "Bash(gh issue status *)",
      "Bash(gh issue view *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh run download *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(glab --version)",
      "Bash(glab auth status *)",
      "Bash(glab ci artifact *)",
      "Bash(glab ci get *)",
      "Bash(glab ci list *)",
      "Bash(glab ci run *)",
      "Bash(glab ci status *)",
      "Bash(glab ci trace *)",
      "Bash(glab ci view *)",
      "Bash(glab issue list *)",
      "Bash(glab job artifact *)",
      "Bash(glab issue view *)",
      "Bash(glab mr create *)",
      "Bash(glab mr diff *)",
      "Bash(glab mr list *)",
      "Bash(glab mr note *)",
      "Bash(glab mr view *)",
      "Bash(glab repo list *)",
      "Bash(glab repo view *)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.vault-pass)"
    ],
    "ask": [
      "Bash(gh *)",
      "Bash(glab *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command'); { echo \"$cmd\" | grep -qiE '\\bgit( +[^ ]+)* +commit\\b' && echo \"$cmd\" | grep -qiE 'claude-session:|co-authored-by:|generated with|noreply@anthropic|🤖' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Commit message contains a vanity trailer/header (Co-Authored-By, Generated with, or robot emoji). Per ~/.claude/CLAUDE.md: no vanity tags/trailers/headers. Remove it and retry.\"}}'; } || true",
            "statusMessage": "Checking commit for vanity trailers"
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/git-guard.sh\"",
            "statusMessage": "Governing git commit/reset/rebase/push"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/no-vcs-powershell.sh\"",
            "statusMessage": "Blocking git/gh/glab in PowerShell"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": false,
  "theme": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": false,
  "_comment_remoteControlAtStartup": "This is a reminder. Actual setting lives in ~/.claude.json. See https://github.com/anthropics/claude-code/issues/54527"
}
